# ─────────────────────────────────────────────
# FileData MCP Server — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Comma-separated list of file sources.
# Supports local paths (CSV or Excel) and HTTPS URLs.
# Examples:
#   FILEDATA_SOURCES=./data/sales.csv
#   FILEDATA_SOURCES=./data/sales.csv,./data/report.xlsx
#   FILEDATA_SOURCES=https://example.com/data.csv,./data/local.xlsx
FILEDATA_SOURCES=

# Transport: stdio (default, for local use) or sse (for OpenWebUI / HTTP clients)
FILEDATA_TRANSPORT=stdio

# SSE / HTTP transport settings (only used when FILEDATA_TRANSPORT=sse)
FILEDATA_HOST=0.0.0.0
FILEDATA_PORT=8000
